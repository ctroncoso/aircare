# ---- InfluxDB ----
INFLUXDB_ORG=home
INFLUXDB_BUCKET=aircare
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=change-me-admin
# Admin token used by Node-RED and Grafana to write/read. Use a long random string.
INFLUXDB_TOKEN=change-me-inlfuxdb-admin-token

# ---- Grafana ----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

# ---- MQTT (HiveMQ Cloud) ----
# Same broker host the devices use (from config.json / secrets.h).
MQTT_BROKER=your-hivemq-broker.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USER=your-mqtt-username
MQTT_PASS=your-mqtt-password

# ---- Misc ----
TZ=America/Santiago
