// HiveMQ Cloud requires username + password on every connection.
// Create this file locally and fill in the credentials you created in the
// HiveMQ Cloud console (Access Management -> Credentials).
//
// This file is gitignored so it never reaches the public repository.
#pragma once

#ifndef MQTT_USER
#define MQTT_USER "USERNAME"
#endif

#ifndef MQTT_PASS
#define MQTT_PASS "PASSWORD"
#endif